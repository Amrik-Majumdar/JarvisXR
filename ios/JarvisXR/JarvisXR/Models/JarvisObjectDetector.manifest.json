      "type": "image",
      "width": 416,
      "height": 416,
      "color_space": "RGB"
    },
    "threshold_inputs": [
      {
        "name": "iouThreshold",
        "type": "double",
        "purpose": "non-maximum-suppression intersection-over-union threshold"
      },
      {
        "name": "confidenceThreshold",
        "type": "double",
        "purpose": "minimum confidence retained by non-maximum suppression"
      }
    ],
    "outputs": [
      {
        "name": "confidence",
        "type": "multiArray",
        "purpose": "class confidence for each retained bounding box"
      },
      {
        "name": "coordinates",
        "type": "multiArray",
        "coordinate_format": "normalized_center_x_center_y_width_height",
        "purpose": "normalized bounding boxes retained by non-maximum suppression"
      }
    ],
    "non_maximum_suppression": true,
    "class_count": 80
